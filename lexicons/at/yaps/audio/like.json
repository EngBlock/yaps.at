{
  "lexicon": 1,
  "id": "at.yaps.audio.like",
  "description": "A like on a voice post.",
  "defs": {
    "main": {
      "type": "record",
      "description": "Record representing a like on a voice post.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef",
            "description": "The voice post being liked."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
