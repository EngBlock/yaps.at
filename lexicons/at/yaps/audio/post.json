{
  "lexicon": 1,
  "id": "at.yaps.audio.post",
  "description": "A voice post. The core unit of content on Yaps.",
  "defs": {
    "main": {
      "type": "record",
      "description": "Record containing a voice post.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["audio", "duration", "createdAt"],
        "properties": {
          "audio": {
            "type": "blob",
            "description": "The audio recording.",
            "accept": ["audio/webm", "audio/ogg"],
            "maxSize": 5242880
          },
          "duration": {
            "type": "integer",
            "description": "Duration of the audio in milliseconds.",
            "minimum": 1,
            "maximum": 300000
          },
          "waveform": {
            "type": "array",
            "description": "Pre-computed amplitude values for waveform visualization, normalized 0-255.",
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            },
            "maxLength": 128
          },
          "reply": {
            "type": "ref",
            "ref": "#replyRef"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    },
    "replyRef": {
      "type": "object",
      "description": "Reference to the post being replied to. Both root and parent are required to support threaded conversations.",
      "required": ["root", "parent"],
      "properties": {
        "root": {
          "type": "ref",
          "ref": "com.atproto.repo.strongRef",
          "description": "The root post of the thread."
        },
        "parent": {
          "type": "ref",
          "ref": "com.atproto.repo.strongRef",
          "description": "The immediate parent post being replied to."
        }
      }
    }
  }
}
