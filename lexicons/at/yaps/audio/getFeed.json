{
  "lexicon": 1,
  "id": "at.yaps.audio.getFeed",
  "description": "Retrieve a feed of voice posts.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns a paginated feed of voice posts.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["posts"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "posts": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "at.yaps.audio.defs#postView"
              }
            }
          }
        }
      }
    }
  }
}
