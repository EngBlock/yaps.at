{
  "lexicon": 1,
  "id": "at.yaps.audio.getAuthorFeed",
  "description": "Retrieve voice posts by a specific author.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns a paginated feed of voice posts from a specific user.",
      "parameters": {
        "type": "params",
        "required": ["actor"],
        "properties": {
          "actor": {
            "type": "string",
            "format": "at-identifier",
            "description": "Handle or DID of the author."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["posts"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "posts": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "at.yaps.audio.defs#postView"
              }
            }
          }
        }
      },
      "errors": [
        {
          "name": "ActorNotFound",
          "description": "The requested actor was not found."
        }
      ]
    }
  }
}
